<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Esharp.LanguageServer.Tests</AssemblyName>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <IncludeCSharp>true</IncludeCSharp>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Esharp.LanguageServer/Esharp.LanguageServer.esproj" />
    <!-- Build-order only: the E# targets' UsingTask loads Esharp.Build.dll. -->
    <ProjectReference Include="../../src/Esharp.Build/Esharp.Build.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
