<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>esharp-lsp</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Esharp.Compiler/Esharp.Compiler.csproj" />
    <!-- Build-order only: the E# targets' UsingTask loads Esharp.Build.dll. -->
    <ProjectReference Include="../Esharp.Build/Esharp.Build.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
